--swiftversion 5.10
--indent 4
--maxwidth 120

# Keep argument names in AppKit delegate/override methods readable.
--stripunusedargs closure-only

# Regular comments above top-level statements are fine (e.g. main.swift).
--disable docComments

# SpecCorpus.swift is generated by scripts/gen-spec-corpus.py; its base64 lines exceed maxwidth.
--exclude macos/MrMark.xcodeproj,macos/build,build,DerivedData,macos/Tests/SpecCorpus.swift
